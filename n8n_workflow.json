    {
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.LARAVEL_URL }}/api/n8n/step",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "Content-Type", "value": "application/json"},
            {"name": "Accept", "value": "application/json"},
            {"name": "X-N8N-Secret", "value": "={{ $vars.N8N_WEBHOOK_SECRET }}"}
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            {"name": "project_id", "value": "={{ $('Prepare Scene Data').first().json.project_id }}"},
            {"name": "step", "value": "4"}
          ]
        },
        "options": {}
      },
      "id": "step4-notify",
      "name": "Notify Step 4",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2880, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.replicate.com/v1/models/minimax/video-01/predictions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "Authorization", "value": "={{ 'Bearer ' + $vars.REPLICATE_API_TOKEN }}"},
            {"name": "Content-Type", "value": "application/json"}
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ input: { prompt: $('Prepare Scene Data').first().json.visual_description, duration: 6 } }) }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "a7b8c9d0-e1f2-3456-a7b8-c9d0e1f2a3b4",
      "name": "Create Replicate Prediction",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [3120, 400]
    },
    {
      "parameters": {
        "jsCode": "const replicateResponse = $input.first().json;\nconst sceneData         = $('Prepare Scene Data').first().json;\nconst audioSavedPath    = `/tmp/audio_scene_${sceneData.scene_number}.mp3`;\n\nif (!replicateResponse.id) {\n  throw new Error('Replicate returned no prediction ID: ' + JSON.stringify(replicateResponse));\n}\n\nreturn [{\n  json: {\n    project_id:    sceneData.project_id,\n    scene_number:  sceneData.scene_number,\n    narration:     sceneData.narration,\n    visual:        sceneData.visual_description,\n    duration:      sceneData.duration_seconds,\n    prediction_id: replicateResponse.id,\n    audio_path:    audioSavedPath,\n    story:         sceneData.story,\n    all_scenes:    sceneData.all_scenes,\n  }\n}];"
      },
      "id": "store-task",
      "name": "Store Task Info",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3360, 400]
    },
    {
      "parameters": {
        "unit": "seconds",
        "amount": 30
      },
      "id": "c9d0e1f2-a3b4-5678-c9d0-e1f2a3b4c5d6",
      "name": "Wait 30 Seconds",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [3600, 400],
      "webhookId": "wait-runway-poll"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://api.replicate.com/v1/predictions/' + $json.prediction_id }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "Authorization", "value": "={{ 'Bearer ' + $vars.REPLICATE_API_TOKEN }}"}
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "d0e1f2a3-b4c5-6789-d0e1-f2a3b4c5d6e7",
      "name": "Check Replicate Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [3840, 400]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "runway-succeeded",
              "leftValue": "={{ $json.status }}",
              "rightValue": "succeeded",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "e1f2a3b4-c5d6-7890-e1f2-a3b4c5d6e7f8",
      "name": "Is Prediction Done?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [4080, 400]
    },
    {
      "parameters": {
        "jsCode": "const predictionStatus = $input.first().json;\nconst taskCtx          = $('Store Task Info').first().json;\n\nconst videoUrl = predictionStatus.output?.[0] ?? '';\nif (!videoUrl) {\n  throw new Error('Replicate succeeded but no output URL found: ' + JSON.stringify(predictionStatus));\n}\n\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData[taskCtx.project_id]) {\n  staticData[taskCtx.project_id] = [];\n}\nstaticData[taskCtx.project_id].push({\n  scene_number: taskCtx.scene_number,\n  video_url:    videoUrl,\n  audio_path:   taskCtx.audio_path,\n  duration:     taskCtx.duration,\n  narration:    taskCtx.narration,\n  visual:       taskCtx.visual,\n});\n\nreturn [{\n  json: {\n    project_id:   taskCtx.project_id,\n    story:        taskCtx.story,\n    all_scenes:   taskCtx.all_scenes,\n    scene_number: taskCtx.scene_number,\n    video_url:    videoUrl,\n    audio_path:   taskCtx.audio_path,\n    duration:     taskCtx.duration,\n    narration:    taskCtx.narration,\n    visual:       taskCtx.visual,\n  }\n}];"
      },
      "id": "f2a3b4c5-d6e7-8901-f2a3-b4c5d6e7f8a9",
      "name": "Extract Scene Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [4320, 280]
    },
    {
      "parameters": {
        "jsCode": "const allItems   = $input.all();\nconst firstScene = allItems[0].json;\n\nconst staticData      = $getWorkflowStaticData('global');\nconst collectedScenes = (staticData[firstScene.project_id] || [])\n  .sort((a, b) => a.scene_number - b.scene_number);\ndelete staticData[firstScene.project_id];\n\nif (collectedScenes.length === 0) {\n  throw new Error('No scene results in static data for project ' + firstScene.project_id);\n}\n\nconst scenesForFfmpeg = collectedScenes.map(s => ({\n  scene_number:       s.scene_number,\n  video_url:          s.video_url,\n  audio_url:          s.audio_path,\n  narration:          s.narration,\n  visual_description: s.visual,\n  duration_seconds:   s.duration,\n}));\n\nconst scenesB64  = Buffer.from(JSON.stringify(scenesForFfmpeg)).toString('base64');\nconst story      = firstScene.story || '';\nconst allScenes  = firstScene.all_scenes || scenesForFfmpeg;\n\nreturn [{\n  json: {\n    project_id:  firstScene.project_id,\n    story,\n    all_scenes:  allScenes,\n    scenes_b64:  scenesB64,\n    output_path: `/storage/videos/${firstScene.project_id}.mp4`,\n  }\n}];"
      },
      "id": "a3b4c5d6-e7f8-9012-a3b4-c5d6e7f8a9b0",
      "name": "Prepare FFmpeg Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [4560, 520]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.LARAVEL_URL }}/api/n8n/step",
        "sendHeaders": true,
        "headerParameters": {
