      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [240, 400],
      "webhookId": "wh-video-pipeline-001"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.LARAVEL_URL }}/api/n8n/step",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "Content-Type", "value": "application/json"},
            {"name": "Accept", "value": "application/json"},
            {"name": "X-N8N-Secret", "value": "={{ $vars.N8N_WEBHOOK_SECRET }}"}
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            {"name": "project_id", "value": "={{ $json.body.project_id }}"},
            {"name": "step", "value": "1"}
          ]
        },
        "options": {}
      },
      "id": "step1-notify",
      "name": "Notify Step 1",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 400]
    },
    {
      "parameters": {
        "jsCode": "const theme = $('Webhook Trigger').first().json.body.theme;\nconst project_id = $('Webhook Trigger').first().json.body.project_id;\n\nconst groqBody = {\n  model: 'llama-3.3-70b-versatile',\n  max_tokens: 8000,\n  messages: [\n    { role: 'system', content: \"Tu es un auteur de livres pour enfants. Tu génères des histoires adaptées à des enfants de 8 ans. Réponds UNIQUEMENT en JSON valide, sans texte avant ou après.\" },\n    { role: 'user', content: `Génère une histoire de 3 minutes (~450 mots) sur le thème : ${theme}.\\nPuis découpe-la en 12 scènes exactement.\\nRéponds UNIQUEMENT en JSON valide avec cette structure :\\n{\\n  \"story\": \"texte complet de l'histoire\",\\n  \"moral\": \"la morale\",\\n  \"scenes\": [\\n    {\\n      \"scene_number\": 1,\\n      \"visual_description\": \"description en anglais, style cartoon coloré pour enfants\",\\n      \"narration\": \"texte exact à narrer pour cette scène\",\\n      \"duration_seconds\": 15\\n    }\\n  ]\\n}\\nAssure-toi que la somme des durées = 180 secondes.` }\n  ]\n};\n\nreturn [{ json: { project_id, theme, groqBody } }];"
      },
      "id": "b2c3d4e5-f6a7-8901-b2c3-d4e5f6a7b8c9",
      "name": "Build Groq Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [720, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "Authorization", "value": "={{ 'Bearer ' + $vars.GROQ_API_KEY }}"},
            {"name": "Content-Type", "value": "application/json"}
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify($json.groqBody) }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "c3d4e5f6-a7b8-9012-c3d4-e5f6a7b8c9d0",
      "name": "Call Groq API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [960, 400]
    },
    {
      "parameters": {
        "jsCode": "const project_id = $('Build Groq Request').first().json.project_id;\nconst theme      = $('Build Groq Request').first().json.theme;\nconst response   = $input.first().json;\n\nconst rawText = response.choices?.[0]?.message?.content ?? '';\n\nlet parsed;\ntry {\n  const cleaned = rawText.replace(/^```json\\s*/i, '').replace(/\\s*```$/, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  throw new Error('Failed to parse Groq JSON response: ' + e.message + '\\nRaw: ' + rawText.slice(0, 500));\n}\n\nif (!parsed.scenes || !Array.isArray(parsed.scenes) || parsed.scenes.length === 0) {\n  throw new Error('Groq returned no valid scenes.');\n}\n\nreturn [{\n  json: {\n    project_id,\n    theme,\n    story:  parsed.story  || '',\n    moral:  parsed.moral  || '',\n    scenes: parsed.scenes,\n  }\n}];"
      },
      "id": "d4e5f6a7-b8c9-0123-d4e5-f6a7b8c9d0e1",
      "name": "Parse Groq Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1200, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.LARAVEL_URL }}/api/n8n/step",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "Content-Type", "value": "application/json"},
            {"name": "Accept", "value": "application/json"},
            {"name": "X-N8N-Secret", "value": "={{ $vars.N8N_WEBHOOK_SECRET }}"}
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            {"name": "project_id", "value": "={{ $json.project_id }}"},
            {"name": "step", "value": "2"}
          ]
        },
        "options": {}
      },
      "id": "step2-notify",
      "name": "Notify Step 2",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1440, 400]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "e5f6a7b8-c9d0-1234-e5f6-a7b8c9d0e1f2",
      "name": "Split Into Scenes",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [1680, 400]
    },
    {
      "parameters": {
        "jsCode": "const batchItem = $input.first().json;\nconst globalData = $('Parse Groq Response').first().json;\n\nreturn [{\n  json: {\n    project_id:         globalData.project_id,\n    story:              globalData.story,\n    moral:              globalData.moral,\n    all_scenes:         globalData.scenes,\n    scene:              batchItem,\n    scene_number:       batchItem.scene_number,\n    narration:          batchItem.narration,\n    visual_description: batchItem.visual_description,\n    duration_seconds:   batchItem.duration_seconds,\n  }\n}];"
      },
      "id": "prep-scene",
      "name": "Prepare Scene Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1920, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.LARAVEL_URL }}/api/n8n/step",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "Content-Type", "value": "application/json"},
            {"name": "Accept", "value": "application/json"},
            {"name": "X-N8N-Secret", "value": "={{ $vars.N8N_WEBHOOK_SECRET }}"}
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            {"name": "project_id", "value": "={{ $json.project_id }}"},
            {"name": "step", "value": "3"}
          ]
        },
        "options": {}
      },
      "id": "step3-notify",
      "name": "Notify Step 3",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2160, 300]
    },
    {
      "parameters": {
        "method": "POST",
