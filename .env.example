APP_NAME="AI Kids Video Generator"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Europe/Paris
APP_URL=https://your-app.up.railway.app

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Base de données ---
# Sur Railway : récupérer DATABASE_URL depuis le plugin MySQL
# Les variables ci-dessous sont auto-injectées par Railway si tu ajoutes le service MySQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=video_kids_generator
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# APIS — voir FREE_API_SETUP.md pour obtenir chaque clé gratuitement
# =============================================================================

# --- Option A : Claude (Anthropic) — $5 de crédit offerts à l'inscription ---
# Inscription : https://console.anthropic.com  →  API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Option B : Groq (GRATUIT, 14 400 req/jour, Llama 3.3 70B) -------------
# Inscription : https://console.groq.com  →  API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# --- Video : Pollinations.ai (GRATUIT, modele LTX-2.3) ---------------------
# Inscription : https://enter.pollinations.ai  →  Créer un compte  →  API Keys
# Tier gratuit (Seed) : 0.15 pollen/heure, largement suffisant pour le demo
POLLINATIONS_VIDEO_ENABLED=true
POLLINATIONS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
POLLINATIONS_VIDEO_MODEL=ltx-2
POLLINATIONS_IMAGE_MODEL=flux
POLLINATIONS_VIDEO_DURATION=5
POLLINATIONS_VIDEO_ASPECT_RATIO=

# --- Voix off : ElevenLabs (plan gratuit 10 000 chars/mois) ----------------
# Inscription : https://elevenlabs.io  →  Profile → API Key
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE_NARRATRICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_VOICE_NARRATEUR_ID=ErXwobaYiN019PkySvjV
ELEVENLABS_VOICE_ENFANT_FILLE_ID=jBpfuIE2acCO8z3wKNLl
ELEVENLABS_VOICE_ENFANT_GARCON_ID=yoZ06aMxZJJ28mfd3POQ
ELEVENLABS_STABILITY=0.38
ELEVENLABS_SIMILARITY_BOOST=0.82
ELEVENLABS_STYLE=0.45
ELEVENLABS_SPEAKER_BOOST=true

# --- Images : Pollinations.ai (100% GRATUIT, aucune clé API requise) -------
# Aucune configuration nécessaire — les images sont générées via URL
# https://image.pollinations.ai/prompt/{description}?width=1280&height=720

# --- Orchestration : N8N Cloud (plan gratuit 2 500 exéc/mois) --------------
# Inscription : https://app.n8n.cloud  →  Credentials
N8N_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/video-pipeline
N8N_WEBHOOK_SECRET=change-me-to-a-long-random-secret

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=eu

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
